#!/bin/bash

# ---------------------------
# HYPR THEME ENGINE (v2 FIXED)
# ---------------------------

set -e

THEME="$1"

if [ -z "$THEME" ]; then
    echo "Usage: theme <theme-name>"
    exit 1
fi

# ---------------------------
# ROOT PATHS (FIXED ARCHITECTURE)
# ---------------------------
ENGINE_ROOT="$HOME/.config/hypr-theme-engine"

THEMES_DIR="$ENGINE_ROOT/themes"
ASSETS_DIR="$ENGINE_ROOT/assets/wallpapers"

CONFIG_DIR="$HOME/.config"

WAYBAR_STYLE="$CONFIG_DIR/waybar/style.css"
KITTY_CONFIG="$CONFIG_DIR/kitty/kitty.conf"

ROFI_THEME="$CONFIG_DIR/rofi/theme.rasi"
ROFI_WALLPAPER="$CONFIG_DIR/rofi/config-wallpaper.rasi"

SWAYNC_STYLE="$CONFIG_DIR/swaync/colors.css"

HYPRLOCK_CONFIG="$CONFIG_DIR/hypr/hyprlock.conf"
HYPR_THEME_LINK="$CONFIG_DIR/hypr/current-theme/theme.conf"

# ---------------------------
# VALIDATION (SAFE)
# ---------------------------
THEME_PATH="$THEMES_DIR/$THEME"

if [ ! -d "$THEME_PATH" ]; then
    notify-send "Theme Engine" "Theme not found: $THEME"
    echo "❌ Theme not found: $THEME_PATH"
    exit 1
fi

# ---------------------------
# WALLPAPER MAP
# ---------------------------
case "$THEME" in
    catppuccin) WP="arch.png" ;;
    violetcore) WP="5.jpeg" ;;
    neoncore)   WP="neoncore5.png" ;;
    monochrome) WP="monochrome.jpg" ;;
    astrocore)  WP="space.jpg" ;;
    tokyonight) WP="tokyonight.png" ;;
    ambercore)  WP="amber.png" ;;
    *)          WP="arch.png" ;;
esac

WALLPAPER_PATH="$ASSETS_DIR/$WP"

# ---------------------------
# APPLY WAYBAR
# ---------------------------
echo "@import \"$THEME_PATH/waybar-${THEME}.css\";" > "$WAYBAR_STYLE"

# ---------------------------
# APPLY ROFI
# ---------------------------
echo "@import \"$THEME_PATH/rofi-${THEME}.rasi\";" > "$ROFI_THEME"
echo "@import \"$THEME_PATH/wallpaper-rofi-${THEME}.rasi\";" > "$ROFI_WALLPAPER"

# ---------------------------
# APPLY SWAYNC
# ---------------------------
echo "@import \"$THEME_PATH/swaync-${THEME}.css\";" > "$SWAYNC_STYLE"

# ---------------------------
# KITTY
# ---------------------------
cp -f "$THEME_PATH/kitty-${THEME}.conf" "$KITTY_CONFIG"

# ---------------------------
# HYPRLAND THEME LINK
# ---------------------------
ln -sf "$THEME_PATH/hypr-${THEME}.conf" "$HYPR_THEME_LINK"

# ---------------------------
# HYPRLOCK (FIXED SOURCE)
# ---------------------------
echo "source = $THEME_PATH/hyprlock-${THEME}.conf" > "$HYPRLOCK_CONFIG"

# ---------------------------
# WALLPAPER APPLY (SAFE)
# ---------------------------
if command -v swaybg >/dev/null 2>&1; then
    swaybg -i "$WALLPAPER_PATH" -m fill &
else
    awww img "$WALLPAPER_PATH" --transition-type grow
fi

# ---------------------------
# RELOAD SYSTEM
# ---------------------------
pkill waybar && nohup waybar >/dev/null 2>&1 &
swaync-client -rs
hyprctl reload

# ---------------------------
# DONE
# ---------------------------
notify-send "Theme Engine" "Switched to: $THEME" -t 3000
