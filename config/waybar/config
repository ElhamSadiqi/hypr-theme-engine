{
  "layer": "top",
  "position": "top",
  "margin-top": 5,
  "margin-left": 10,
  "margin-right": 10,

  "modules-left": [
    "custom/arch",
    "custom/weather"
  ],

  "modules-center": [
    "clock",
    "hyprland/workspaces"
  ],

  "modules-right": [
    "pulseaudio",
    "network",
    "battery",
    "custom/notification"
  ],

  "custom/arch": {
    "format": "َ°£‡",
    "tooltip": false, 
    "on-click": "$HOME/.config/rofi/wallpaper-picker"
  },

  "custom/weather": {
    "exec": "$HOME/.config/scripts/weather.sh",
    "interval": 1800,
    "return-type": "json"
  },

  "clock": {
  "format": "{:%I:%M %p}",
  "tooltip-format": "{:%A, %d %B %Y}"
  }, 

  "hyprland/workspaces": {
    "format": "{name}",
    "on-click": "activate",
    "all-outputs": true,
    "persistent-workspaces": {
      "*": 5
    }
  },

  "network": {
    "format-wifi": "َ°–© {essid}",
    "format-ethernet": "َ°ˆ€",
    "format-disconnected": "offline",
    "on-click": "kitty impala"
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "َ°–پ muted",
    "format-icons": {
       "headphone": "َ°‹‹",
       "hands-free": "َ°‹ژ",
       "headset": "َ°‹ژ",
       "phone": "َ°ڈ²",
       "portable": "َ°ڈ²",
       "car": "َ°„‹",
       "default": ["َ°•؟", "َ°–€", "َ°•¾"]
    },
    "scroll-step": 5
  },

  "battery": {
  "format": "{icon}  {capacity}%",
  "format-charging": "َ°‚„ {capacity}%",
  "format-icons": ["ï‰„", "ï‰ƒ", "ï‰‚", "ï‰پ", "ï‰€"]
  },
  
  "custom/notification": {
    "tooltip": false,
    "format": "َ°‚ڑ",
    "on-click": "swaync-client -t -sw",
    "escape": true
  }
}
