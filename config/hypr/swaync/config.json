{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
  "cssPriority": "user",

  "control-center-width": 300,
  "control-center-height": 700, 
  "control-center-margin-top": 8,
  "control-center-margin-bottom": 8,
  "control-center-margin-right": 12,
  "control-center-margin-left": 8,

  "notification-window-width": 400,
  "notification-icon-size": 48,
  "notification-body-image-height": 0,
  "notification-body-image-width": 0,

  "timeout": 4,
  "timeout-low": 2,
  "timeout-critical": 6,
  
  "fit-to-screen": false,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 250,
  "hide-on-clear": false,
  "hide-on-action": false,
  "script-fail-notify": true,

  "widgets": [
    "mpris",
    "buttons-grid",
    "volume",
    "backlight",
    "dnd",
    "title",
    "notifications"
  ],

  "widget-config": {
    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": "Clear All"
    },
    "dnd": {
      "text": "Do not disturb",
      "do-not-disturb-on-startup": false
    },
    "mpris": {
      "image-size": 60,
      "image-radius": 12,
      "show-album-art": "playing",
      "blur-background": false,
      "autohide": false
    },
    "volume": {
      "label": ""
    },
    "backlight": {
      "label": "",
      "device": "intel_backlight",
      "subsystem": "backlight", 
      "min": 10
    },
    "buttons-grid": {
      "n-cols": 4,
      "actions": [
        { "label": "", "command": "thunar /home/Arch" },
        { "label": "", "command": "~/.config/swaync/scripts/wifi-toggle.sh" },
        { "label": "", "command": "~/.config/swaync/scripts/bluetooth-toggle.sh" },
        { "label": "", "command": "systemctl poweroff" }
      ]
    }
  }
}
